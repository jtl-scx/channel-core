{
    "name": "jtl-scx/channel-core",
    "type": "library",
    "description": "SCX Channel Library",
    "license": "MIT",
    "require": {
        "php": "8.3.* || 8.4.*",
        "ext-curl": "*",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.14.1",
        "jtl-scx/api-base-client": "^1.7.0",
        "jtl-software/opsgenie-client": "^2.1",
        "jtl/go-prometrics-client": "^3.2",
        "jtl/nachricht": "0.19.6",
        "jtl/php-generic-collection": "0.5.0 || ^1.0.1",
        "monolog/monolog": "^2.11.0",
        "myclabs/php-enum": "^1.8.5",
        "php-amqplib/php-amqplib": "^3.7.4",
        "psr/clock": "^1.0",
        "psr/log": "^3.0.2",
        "symfony/config": "^6.4.42",
        "symfony/console": "^6.4.42",
        "symfony/dependency-injection": "^6.4.42",
        "symfony/proxy-manager-bridge": "^6.4.28",
        "symfony/translation": "^6.4.42",
        "symfony/yaml": "^6.4.42"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": " ^3.95.13",
        "phpstan/phpstan": "^1.12.33",
        "phpunit/phpunit": "^9.6.35",
        "symfony/dotenv": "^6.4.42",
        "twig/twig": "^2.0 || ^3.28.0"
    },
    "suggest": {
        "jtl/go-prometrics-client": "Needed if Metric Collection is used"
    },
    "autoload": {
        "psr-4": {
            "JTL\\SCX\\Lib\\Channel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JTL\\SCX\\Lib\\Channel\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": [
            "vendor/bin/php-cs-fixer fix"
        ],
        "phpcs-dry": [
            "vendor/bin/php-cs-fixer fix --dry-run"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse -c phpstan.neon"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
